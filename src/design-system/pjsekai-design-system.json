    "textStyles": {
      "menuTitle": {
        "fontFamily": "display",
        "fontSize": "1.5rem",
        "fontWeight": 700,
        "letterSpacing": "0.02em",
        "textTransform": "uppercase"
      },
      "buttonJapanese": {
        "fontFamily": "primary",
        "fontSize": "1rem",
        "fontWeight": 700,
        "letterSpacing": "0.05em"
      },
      "buttonEnglish": {
