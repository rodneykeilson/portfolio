  "cssVariables": {
    "description": "Ready-to-use CSS custom properties",
    "output": ":root {\n  /* Colors */\n  --sekai-cyan: #00D4AA;\n  --sekai-cyan-glow: #00FFD0;\n  --sekai-pink: #FF6B9D;\n  --sekai-purple: #9B5DE5;\n  --sekai-blue: #00B4D8;\n  --sekai-yellow: #FFD93D;\n\n  /* Backgrounds */\n  --bg-void: #050508;\n  --bg-primary: #0A0A12;\n  --bg-secondary: #0F0F1A;\n  --bg-card: #141420;\n  --bg-elevated: #1A1A2E;\n\n  /* Glass */\n  --glass-bg: rgba(20, 20, 32, 0.7);\n  --glass-border: rgba(255, 255, 255, 0.06);\n\n  /* Text */\n  --text-primary: #F5F5FF;\n  --text-secondary: #A0A0B8;\n  --text-muted: #606080;\n\n  /* Shadows */\n  --glow-cyan: 0 0 20px rgba(0, 212, 170, 0.2);\n  --glow-cyan-strong: 0 0 40px rgba(0, 212, 170, 0.4);\n\n  /* Fonts */\n  --font-display: 'Zen Kaku Gothic New', 'M PLUS 1p', system-ui, sans-serif;\n  --font-heading: 'Outfit', 'Exo 2', system-ui, sans-serif;\n\n  /* Transitions */\n  --transition-default: all 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);\n  --easing-sekai: cubic-bezier(0.25, 0.1, 0.25, 1);\n}"
  }
