        "fontSize": "1.25rem",
        "fontWeight": 700,
        "letterSpacing": "0.02em"
      },
      "bodyText": {
        "fontFamily": "primary",
        "fontSize": "0.875rem",
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    }
  },

