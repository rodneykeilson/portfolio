{
  "meta": {
    "name": "Project Sekai: Colorful Stage Design System",
    "version": "1.0.0",
    "description": "Comprehensive design system recreating the authentic Project Sekai UI aesthetic for portfolio use",
    "sources": [
      "Extracted game textures (TopMenuAtlas, CommonAtlas, FrameAtlas, HeaderTitleAtlas)",
      "Official SEGA/Colorful Palette game UI",
      "Project Sekai visual identity analysis"
    ]
  },

  "typography": {
    "description": "Project Sekai uses a mix of clean Japanese gothic fonts with geometric display faces. The primary font is FOT-Rodin Pro (Fontworks), a modern humanist sans-serif. For web alternatives, we use fonts with similar characteristics.",
    
    "fontFamilies": {
      "primary": {
        "name": "FOT-Rodin Pro / UD Kaku Gothic",
        "description": "The main UI font - clean, modern Japanese gothic with excellent readability",
        "webAlternatives": [
          "'Zen Kaku Gothic New'",
          "'M PLUS 1p'",
          "'Noto Sans JP'",
          "'Hiragino Sans'"
        ],
        "fallback": "system-ui, -apple-system, sans-serif",
        "css": "'Zen Kaku Gothic New', 'M PLUS 1p', 'Noto Sans JP', system-ui, sans-serif",
        "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@300;400;500;700;900&family=M+PLUS+1p:wght@300;400;500;700;800&display=swap"
      },
      "display": {
        "name": "Geometric Display",
        "description": "Used for large headings, menu titles, and impact text. Slightly condensed, bold weights.",
        "webAlternatives": [
          "'Outfit'",
          "'Exo 2'",
          "'Orbitron'",
          "'Rajdhani'"
        ],
        "css": "'Outfit', 'Exo 2', system-ui, sans-serif",
        "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Exo+2:wght@400;500;600;700;800&display=swap"
      },
      "english": {
        "name": "English UI Text",
        "description": "Used for English labels alongside Japanese text. Clean geometric sans.",
        "css": "'Inter', 'Outfit', system-ui, sans-serif"
      }
    },

    "fontSizes": {
      "xs": { "size": "0.625rem", "px": "10px", "use": "Tiny labels, timestamps" },
      "sm": { "size": "0.75rem", "px": "12px", "use": "Small labels, captions" },
      "base": { "size": "0.875rem", "px": "14px", "use": "Body text, descriptions" },
      "md": { "size": "1rem", "px": "16px", "use": "Standard UI text" },
      "lg": { "size": "1.125rem", "px": "18px", "use": "Emphasized text" },
      "xl": { "size": "1.25rem", "px": "20px", "use": "Section labels" },
      "2xl": { "size": "1.5rem", "px": "24px", "use": "Card titles" },
      "3xl": { "size": "2rem", "px": "32px", "use": "Section headers" },
      "4xl": { "size": "2.5rem", "px": "40px", "use": "Page titles" },
      "5xl": { "size": "3rem", "px": "48px", "use": "Hero text" },
      "6xl": { "size": "4rem", "px": "64px", "use": "Display text" }
    },

    "fontWeights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800,
      "black": 900
    },

    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em",
      "japanese": "0.05em"
    },

    "lineHeight": {
      "none": 1,
      "tight": 1.25,
      "snug": 1.375,
      "normal": 1.5,
      "relaxed": 1.625,
      "loose": 2
