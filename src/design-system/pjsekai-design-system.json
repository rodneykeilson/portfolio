  "components": {
    "button": {
      "description": "Project Sekai buttons feature trapezoid/parallelogram shapes with Japanese text as primary and small English text as secondary label.",
      
      "variants": {
        "primary": {
          "background": "linear-gradient(135deg, #00D4AA 0%, #00A888 100%)",
          "backgroundHover": "linear-gradient(135deg, #33E5C4 0%, #00D4AA 100%)",
          "backgroundActive": "#00A888",
          "textColor": "#0A0A12",
